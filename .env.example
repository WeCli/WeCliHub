# GitHub OAuth (required for login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Recommended: set explicitly in production, e.g.
# https://clawcross.net/auth/github/callback
# If omitted, app will derive callback from current request host.
GITHUB_REDIRECT_URI=

# Session signing key (required in production)
SESSION_SECRET=

# OpenAI-compatible translation API (used to bilingualize imported/published workflows)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CLAWCROSSHUB_TRANSLATION_MODEL=gpt-4.1-mini
# Set to 1 to disable automatic EN/ZH localization during import/publish/update
CLAWCROSSHUB_DISABLE_AUTO_TRANSLATION=0
